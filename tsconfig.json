{
  "compilerOptions": {
    "target": "ES2022",
    /* Runtime */
    "module": "node16",
    "moduleResolution": "node16",

    /* Paths */
    "rootDir": "src",
    "outDir": "dist",

    /* Strict */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Interop */
    "esModuleInterop": true,

    /* DX */
    "skipLibCheck": true,
    "resolveJsonModule": true,

    /* Types */
    "types": ["node", "jest"],

    /* Debug */
    "sourceMap": true
  },
  "include": ["src"]
}